generator client {
  provider = "prisma-client-js"
}

// SQLite cho bản chạy nội bộ / LAN — lên cloud chỉ cần đổi provider sang postgresql (Supabase)
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  // email/phone: cần ÍT NHẤT MỘT trong hai (enforce trong code — SQLite/Prisma không có CHECK).
  // email nullable để cho phép đăng ký bằng SĐT; phone chuẩn hoá dạng 0xxxxxxxxx (VN).
  email        String?  @unique
  phone        String?  @unique
  name         String
  passwordHash String
  credits      Int      @default(200)
  isAdmin      Boolean  @default(false)
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  // Avatar config JSON — schema: { base:1..4, hair:1..8, hairColor:'black|brown|blonde|red|silver',
  // glasses:'none|round|square|aviator|rimless|cateye', hat:'none|fedora|beanie|cap|headphone|hairband',
  // shirt:'hoodie|sweater|blazer|tshirt|turtleneck|dress', shirtColor:'navy|orange|beige|gray|white' }.
  // Null = chưa chọn → fallback deterministic từ id.
  avatar       String?

  flows        Flow[]
  transactions CreditTransaction[]
  messages     ChatMessage[]
  assets       LibraryAsset[]
  projects     Project[]
  integrations IntegrationAccount[]
  larkUserMaps LarkUserMap[]
}

// Token OAuth của user cho từng dịch vụ ngoài (google/ms365/zoom/zalo/spotify/youtube/team...).
// accessToken/refreshToken LƯU DẠNG MÃ HOÁ (AES-256-GCM, xem lib/integrations/crypto.ts) —
// SQLite là file trên đĩa, không lưu token thô. Mỗi user × provider chỉ 1 bản ghi.
model IntegrationAccount {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  accessToken  String // đã mã hoá
  refreshToken String? // đã mã hoá
  scope        String   @default("")
  expiresAt    DateTime?
  meta         String? // JSON tuỳ dịch vụ (account id, email, tenant...)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Project {
  id         String   @id @default(cuid())
  userId     String
  name       String
  clientName String?
  createdAt  DateTime @default(now())
  // ══ MỚI (docs/RESEARCH-HOME-GALLERY-DASHBOARD.md §2.1) ══ — "Mã DA" bên Larkbase, gán TUỲ
  // CHỌN lúc tạo/sửa dự án ("Liên kết Larkbase"). Optional — không phải Project nào cũng có
  // mã Larkbase (dự án mới trong IF trước khi phòng dự án tạo task tương ứng bên Larkbase).
  larkProjectCode String?

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  flows    Flow[]
  notebook ProjectNotebook?

  @@index([larkProjectCode])
}

// ══════════════════════════════════════════════════════════════════════════
// Project Notebook (Phase 1) — "NotebookLM riêng cho mỗi project".
// User upload PDF/ảnh/note → extract → chunk → embed (NVIDIA) → cosine retrieve
// tại chỗ (JSON blob) → RAG cho Vitals chat. Không thêm pgvector/sqlite-vss
// (option 🅐: đơn giản, không dependency mới; hàng nghìn chunk vẫn nhanh trong Node).
// ══════════════════════════════════════════════════════════════════════════
model ProjectNotebook {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sources NotebookSource[]
  chunks  NotebookChunk[]
}

model NotebookSource {
  id          String   @id @default(cuid())
  notebookId  String
  notebook    ProjectNotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  kind        String   // "pdf" | "image" | "text" | "url" | "meeting-note"
  title       String
  originalUrl String?
  filePath    String?  // path lưu local (uploads/notebook/{projectId}/{sourceId}.{ext})
  mimeType    String?
  sizeBytes   Int?
  status      String   @default("processing") // "processing" | "ready" | "error"
  errorMsg    String?
  createdAt   DateTime @default(now())

  chunks NotebookChunk[]

  @@index([notebookId])
}

model NotebookChunk {
  id         String   @id @default(cuid())
  notebookId String
  notebook   ProjectNotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  sourceId   String
  source     NotebookSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  page       Int?
  content    String
  embedding  String // JSON array float32[]
  tokens     Int?
  createdAt  DateTime @default(now())

  @@index([notebookId])
  @@index([sourceId])
}

model Flow {
  id         String   @id @default(cuid())
  userId     String
  projectId  String?
  name       String   @default("Untitled flow")
  graphJson  String   @default("{\"nodes\":[],\"edges\":[]}")
  coverUrl   String   @default("") // ảnh bìa card chọn tay (url thư viện hoặc cover mặc định); trống = fallback hash-cover
  status     String   @default("") // dòng trạng thái ngắn hiện dưới tên dự án; trống = "Chưa có ghi chú"
  version    Int      @default(1)
  shareToken String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  versions FlowVersion[]
}

// snapshot khi Run flow — version không ghi đè
model FlowVersion {
  id        String   @id @default(cuid())
  flowId    String
  version   Int
  graphJson String
  createdAt DateTime @default(now())

  flow Flow @relation(fields: [flowId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int // âm = trừ, dương = nạp/hoàn
  reason    String
  jobRef    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  text      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// thư viện dùng chung cả team — file lưu ./uploads, DB giữ metadata
model LibraryAsset {
  id        String   @id @default(cuid())
  userId    String
  name      String
  category  String
  tags      String   @default("")
  mime      String
  path      String
  // ---- Gu Engine: chưng cất gu từ ref (07/07) ----
  usage     String   @default("ref-render") // RefUsage: ref-render | slide | material | layout | cad | brief
  palette   String   @default("")           // JSON string[] hex — màu chủ đạo trích từ ảnh
  caption   String   @default("")           // mô tả gu (VLM hoặc tay)
  content   String?                         // chữ bóc từ PDF (đề bài/hồ sơ) cho AI đọc
  w         Int      @default(0)
  h         Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ══════════════════════════════════════════════════════════════════════════
// Home/Gallery ↔ Larkbase (docs/RESEARCH-HOME-GALLERY-DASHBOARD.md) — M1.
// PULL-ONLY tuyệt đối: Larkbase là nguồn chân lý, IF chỉ đọc/mirror, KHÔNG BAO GIỜ ghi ngược
// (không create_record/update_record tự động — xem §2.4 báo cáo). Cùng mẫu hình MaterialRef
// đã đề xuất ở RESEARCH-MATERIAL-BRIDGE.md §2: bảng mirror cache đọc + field `raw` JSON giữ
// nguyên toàn bộ dữ liệu gốc (tương lai-proof, Larkbase thêm cột không cần migrate).
// ══════════════════════════════════════════════════════════════════════════

// Mirror bảng "Chi tiết công việc" (tblnjLehkr6DRMJN mặc định, xem LARK_TASK_TABLE_ID).
model LarkTaskRef {
  id              String    @id @default(cuid())
  larkRecordId    String    @unique // record_id thật — khoá đối chiếu khi sync lại (idempotent)
  task            String                      // Công việc (fldwbtnkvV)
  larkProjectName String                      // Dự án — TEXT TỰ DO bên Larkbase (fldJtylsyv)
  larkProjectCode String?                     // Mã DA (fldhMYuiEN) — "Khác"/rỗng/không phải số → null
  ownerAccount    String?                     // Chủ trì — Tài khoản Lark (fldgKYaap5), CHƯA map User.id
  status          String                      // Trạng thái: 'Đang làm'|'Hoàn thành'|'Ghi nhận' (fldfhchOp2)
  deadline        DateTime?                   // fldhG7EqAa
  daysLeft        Int?                        // Số ngày còn lại — ĐỌC TỪ FORMULA CÓ SẴN (fldKUidfNt)
  warningLabel    String?                     // Cảnh báo — ĐỌC TỪ FORMULA CÓ SẴN (fldz1WLW4y), giữ emoji
  raw             String                      // JSON toàn bộ field gốc Larkbase
  syncedAt        DateTime  @default(now())

  @@index([larkProjectCode])
  @@index([status])
}

// Mirror bảng "Nhân sự" (tblUvVYG5j70FCTn mặc định, xem LARK_HR_TABLE_ID). BỔ SUNG so với
// danh sách model gốc trong báo cáo (chỉ liệt LarkTaskRef/LarkUserMap) — cần 1 nơi lưu roster
// cho tab "Nhân sự" của panel "Chi tiết" (không có field nhạy cảm, xem báo cáo §1.5/§3: chỉ
// Tài khoản/Họ tên/Chức danh/Phòng ban/checkbox Team Crea, an toàn hiện công khai nội bộ).
// Cùng mẫu pull-only/idempotent như LarkTaskRef — KHÔNG phải "phát minh cơ chế lưu token mới",
// đây là mirror DỮ LIỆU, không phải lưu credential.
model LarkPersonRef {
  id           String   @id @default(cuid())
  larkRecordId String   @unique
  larkAccount  String   @unique // Tài khoản (fldRj0Rxqj, primary) — vd "An.LNT"
  fullName     String                       // Họ tên (fldrqrWgRL)
  title        String?                      // Chức danh (fldk6eUee1)
  department   String?                      // Phòng ban (fldtdBj7Vw)
  isCrea       Boolean  @default(false)      // Team Crea (fldvno5ztZ, checkbox)
  raw          String
  syncedAt     DateTime @default(now())
}

// ══════════════════════════════════════════════════════════════════════════
// Hệ Legend (docs/PROPOSAL-LEGEND-SYSTEM.md §2, X1) — spec sản phẩm/vật liệu THỐNG NHẤT,
// nguồn dữ liệu cho MỌI legend/schedule/spec-sheet ở cả 3 chặng. Quyết định Q-L2 đã chốt:
// GỘP MaterialRef (RESEARCH-MATERIAL-BRIDGE) vào đây với kind='material' — 1 bảng duy nhất.
// Giá mirror Larkbase pull-only (mẫu LarkTaskRef) nhưng ĐỂ TRỐNG được — Q1 bridge chưa chốt.
// ══════════════════════════════════════════════════════════════════════════
model ProductSpec {
  id           String    @id @default(cuid())
  kind         String                       // 'furniture' | 'material' | 'lighting' | 'millwork' | 'fixture'
  name         String                       // "Ghế Volumen Lounge"
  nameEn       String?                      // song ngữ TTT: "Volumen Lounge Chair"
  brand        String?
  sku          String?
  vendor       String?
  // kích thước danh nghĩa mm (khớp BlockDef.w/h; d = sâu, hUp = cao thật 3D cho spec sheet)
  w            Int?
  d            Int?
  hUp          Int?
  materials    String    @default("")       // JSON string[] — ['oak','linen']
  finishes     String    @default("")       // JSON string[] — fabric/finish options
  colorHex     String?                      // swatch chính
  imageAssetId String?                      // FK mềm LibraryAsset — lưu-theo-tham-chiếu
  drawingBlock String?                      // key BlockDef/manifest id — line drawing top-view có sẵn
  priceNote    String?                      // text tự do "1.250.000đ/cái" — chưa chuẩn hoá số
  currency     String?                      // 'VND' | 'USD' | 'EUR'
  larkRecordId String?   @unique            // khoá sync nếu record đến từ Larkbase
  raw          String?                      // JSON field gốc Larkbase (mẫu LarkTaskRef)
  note         String?
  createdAt    DateTime  @default(now())
  syncedAt     DateTime?

  @@index([kind])
  @@index([sku])
  @@index([drawingBlock])
}

// Ánh xạ TAY 1 lần: "Tài khoản" Larkbase (vd "An.LNT") ↔ User.id nội bộ IF — Larkbase KHÔNG
// dùng cùng định danh (tên đầy đủ/email) nên không tự suy đoán được (báo cáo §3, câu hỏi (f)).
// Phân quyền app KHÔNG phụ thuộc bảng này (đã chốt tách biệt hoàn toàn — ProjectMember riêng,
// xem RESEARCH-ACCESS-CONTROL.md); đây chỉ để HIỂN THỊ (tooltip chức danh/phòng ban, cột
// "Chủ trì" trong bảng phẳng) và pre-fill gợi ý sau này, không quyết quyền truy cập.
model LarkUserMap {
  id          String   @id @default(cuid())
  larkAccount String   @unique
  userId      String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
