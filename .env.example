# --- Auth ---
# Bí mật ký JWT session (if_session) — đổi khi lên môi trường thật
AUTH_SECRET=

# Google Sign-In (OAuth 2.0 tự viết, không NextAuth). Tạo ở Google Cloud Console:
# APIs & Services → Credentials → OAuth client ID (Web application),
# thêm Authorized redirect URI:  http://localhost:3000/api/auth/google/callback
# (đổi host/port theo origin thật khi chạy LAN). Thiếu 2 key này → nút Google hiện "cần cấu hình".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sign in with Apple — CHƯA BẬT (cần Apple Developer trả phí + key .p8). Để sẵn khung:
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Phase 2+ — chưa dùng ở Phase 1
FAL_KEY=
ANTHROPIC_API_KEY=
DATABASE_URL=
REDIS_URL=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ============================================================================
# TÍCH HỢP DỊCH VỤ NGOÀI (server-only — TUYỆT ĐỐI không thêm tiền tố NEXT_PUBLIC_).
# Redirect URI mỗi provider:  <origin>/api/integrations/<provider>/callback
# Hướng dẫn lấy khoá + rủi ro: docs/INTEGRATIONS.md. Thiếu khoá → provider hiện "chưa cấu hình".
# ============================================================================
# Khoá mã hoá token OAuth at-rest (BẮT BUỘC nếu dùng tích hợp OAuth). Tạo: openssl rand -base64 32
INTEGRATION_ENC_KEY=

# Google Workspace (Gmail/Calendar/Drive) — DÙNG LẠI GOOGLE_CLIENT_ID/SECRET ở trên.
# MS365 (Microsoft Graph — Outlook mail/calendar) + ĐĂNG NHẬP MICROSOFT (app/api/auth/microsoft).
# Cùng MỘT Azure App Registration — hướng dẫn: docs/INTEGRATIONS.md mục "Đăng nhập Microsoft".
# Redirect URI login:  <origin>/api/auth/microsoft/callback
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=
MS365_TENANT=common

# Zoom (tạo meeting) — Zoom Marketplace OAuth app.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Team API nội bộ (adapter generic) — chờ spec đội.
TEAM_API_BASE=
TEAM_API_TOKEN=

# Zalo Official Account / ZNS (KHÔNG hỗ trợ Zalo cá nhân).
ZALO_OA_APP_ID=
ZALO_OA_SECRET=

# Spotify (metadata/nhúng — playback đầy đủ cần SDK+premium).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube Data API v3 (tìm/nhúng video — quota-limited). (YOUTUBE_CLIENT_ID/SECRET nếu cần OAuth.)
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Apple Music (MusicKit) — STUB, chưa dựng flow. Cần Apple Developer + .p8.
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=

# Lark/Feishu Base (Bitable) — server-to-server, KHÔNG OAuth per-user (đọc 1 base dùng chung
# công ty). Home/Gallery "Đồng bộ tiến độ" + panel "Chi tiết" (docs/RESEARCH-HOME-GALLERY-
# DASHBOARD.md). Hướng dẫn tạo app + lấy khoá: docs/INTEGRATIONS.md mục "Lark/Feishu Base".
LARK_APP_ID=
LARK_APP_SECRET=
# Token của chính cái Base (phần {app_token} trong URL base, KHÁC table_id) — bắt buộc để gọi
# Bitable API, không đoán được từ App ID/Secret.
LARK_BASE_APP_TOKEN=
# https://open.larksuite.com (Lark quốc tế, mặc định) hoặc https://open.feishu.cn (Feishu TQ).
LARK_API_BASE=
# table_id 2 bảng — có mặc định đúng theo báo cáo đã verify, đổi nếu Larkbase tái cấu trúc.
LARK_TASK_TABLE_ID=tblnjLehkr6DRMJN
LARK_HR_TABLE_ID=tblUvVYG5j70FCTn
